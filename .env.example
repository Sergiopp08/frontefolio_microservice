# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=frontefolio
DB_USER=root
DB_PASSWORD=yourpassword

# JWT
JWT_SECRET=your_super_secret_key_change_in_production
JWT_EXPIRES_IN=7d

# Pasarela de pago (simulada)
# Tarjetas que se consideran válidas, separadas por comas
VALID_CARDS=4111111111111111,5500005555555554,4000000000000002

# Frontend URLs (para CORS)
FRONTEND_CUSTOMER_URL=http://localhost:5173
FRONTEND_ADMIN_URL=http://localhost:5174
